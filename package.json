    "@types/sql.js": "^1.4.11",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "d3-scale-chromatic": "^3.1.0",
    "pokemon-showdown": "file:vendor/pokemon-showdown-0.11.10-champions-master-e440c4a.tgz",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sql.js": "^1.14.1"
  },
