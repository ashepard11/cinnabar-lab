    "build-viz1": "tsx scripts/build-viz1.ts",
    "build-viz2": "tsx scripts/build-viz2.ts",
    "build-all": "npm run scrape && npm run build-variants && npm run build-viz1 && npm run build-viz2",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p . && tsc -p tsconfig.web.json",
    "sanity": "tsx scripts/sanity-checks.ts",
    "test": "tsx scripts/phase0-smoke.ts && tsx scripts/test-variants.ts && tsx scripts/sanity-checks.ts && tsx scripts/test-variant-cid.ts",
    "test-cid": "tsx scripts/test-variant-cid.ts",
    "migrate-matchups": "tsx scripts/migrate-matchups-v2.ts",
    "verify-matchups": "tsx scripts/verify-matchups.ts",
    "sim-smoke": "tsx scripts/sim-smoke.ts",
    "inspect-matchup": "tsx scripts/inspect-matchup.ts",
    "sim-sanity": "tsx scripts/sim-sanity.ts",
    "endgame-suite": "tsx scripts/endgame-suite.ts",
    "build-matchups": "tsx scripts/build-matchups.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashepard11/cinnabar-lab.git"
  },
  "license": "MIT",
  "dependencies": {
