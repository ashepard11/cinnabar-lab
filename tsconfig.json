{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["lib/**/*.ts", "scripts/**/*.ts", "src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
